# Obsidian-OS Konfiguration
# cp .env.example .env  →  Werte ausfüllen  →  npm run dev

# ── Pflichtfelder ─────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather → /newbot)
BOT_TOKEN=

# Pfad zum Obsidian-Vault
# Windows: C:\Users\julius\Documents\MeinVault
# macOS:   /Users/julius/Documents/MeinVault
WORKSPACE_PATH=

# ── Ollama (Pflicht) ──────────────────────────────────────────────────────────

# API-URL
# Ollama Cloud: https://api.ollama.com/v1
# Lokal:        http://localhost:11434/v1
OLLAMA_BASE_URL=https://api.ollama.com/v1

# Hauptmodell
# Cloud: kimi-k2.5:cloud, llama3.3:cloud, qwen3:235b
# Lokal: qwen2.5:7b, llama3.2:3b
OLLAMA_MODEL=kimi-k2.5:cloud

# Modell für /fast Modus (optional, Standard = OLLAMA_MODEL)
# OLLAMA_FAST_MODEL=qwen2.5:7b

# Sub-Agenten Modell (optional, Standard = OLLAMA_MODEL)
# OLLAMA_SUBAGENT_MODEL=qwen2.5:7b

# ── Vision / Bilder (optional) ────────────────────────────────────────────────

# Multimodales Modell für Foto-Analyse und OCR
# Muss Vision unterstützen: llava, qwen2.5-vl, llama3.2-vision, minicpm-v
# Wenn leer → OLLAMA_MODEL wird verwendet
# VISION_MODEL=llava

# ── Sprachnachrichten / Whisper (lokal, kein API-Key) ────────────────────────
#
# Installation (einmalig):
#   pip install openai-whisper
#   (+ ffmpeg: https://ffmpeg.org/download.html)
#
# Modelle (Größe / Qualität):
#   tiny     ~39MB   – sehr schnell, weniger genau
#   base     ~74MB   – schnell
#   small    ~244MB  – gut
#   medium   ~769MB  – sehr gut
#   large-v3 ~1.5GB  – beste Qualität  ← Standard
#
# Wird beim ersten Aufruf automatisch heruntergeladen.
WHISPER_MODEL=large-v3
WHISPER_LANG=de

# ── Sicherheit ────────────────────────────────────────────────────────────────

# Nur diese Chat-ID darf den Bot nutzen (empfohlen)
# Herausfinden: Bot starten → /whoami
ALLOWED_CHAT_ID=

# ── Obsidian-Ordner (optional) ────────────────────────────────────────────────

# DAILY_NOTES_DIR=Daily
# TEMPLATES_DIR=Templates
# ATTACHMENTS_DIR=Attachments
