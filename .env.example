# Obsidian-OS Konfiguration
# Wird automatisch vom Install-Script befuellt

# ── Pflicht ───────────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather)
BOT_TOKEN=

# Vault-Pfad (im Container immer /vault)
WORKSPACE_PATH=/vault

# LLM API (OpenAI-kompatibel: Ollama Cloud, OpenAI, OpenRouter, lokales Ollama)
# Cloud:  https://api.ollama.com/v1
# OpenAI: https://api.openai.com/v1
OLLAMA_BASE_URL=https://api.ollama.com/v1

# API Key (Ollama Cloud, OpenAI, OpenRouter)
OLLAMA_API_KEY=

# LLM-Modell
OLLAMA_MODEL=kimi-k2.5:cloud

# ── Sicherheit ────────────────────────────────────────────────────────────────

# Nur diese Chat-ID darf den Bot nutzen (Bot starten → /whoami)
ALLOWED_CHAT_ID=

# ── OneDrive (rclone im Container) ───────────────────────────────────────────

# Token von: rclone authorize "onedrive" (am lokalen PC ausfuehren)
RCLONE_TOKEN=

# Pfad zum Vault innerhalb von OneDrive (z.B. Obsidian/MeinVault)
ONEDRIVE_VAULT_PATH=

# Drive-Typ: personal / business
ONEDRIVE_DRIVE_TYPE=personal

# Drive-ID (nur noetig bei mehreren OneDrive-Konten, sonst leer lassen)
ONEDRIVE_DRIVE_ID=

# ── Optional ──────────────────────────────────────────────────────────────────

# OLLAMA_FAST_MODEL=qwen2.5:7b
# OLLAMA_SUBAGENT_MODEL=qwen2.5:7b
# VISION_MODEL=llava
# WHISPER_MODEL=large-v3
# WHISPER_LANG=de
