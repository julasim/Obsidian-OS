# Obsidian-OS Konfiguration

# ── Pflicht ───────────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather)
BOT_TOKEN=

# Vault-Pfad (im Container immer /vault)
WORKSPACE_PATH=/vault

# ── LLM-Provider ─────────────────────────────────────────────────────────────
# OpenRouter = Default (ein Key, viele Modelle: Claude, GPT-4o, Gemini, Llama...)
# Key holen: https://openrouter.ai → Dashboard → API Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-...

# Modell (OpenRouter-Format: provider/model).
#
# Stealth (empfohlen — gratis, Frontier-Qualitaet, starkes Tool-Calling):
#   openrouter/elephant-alpha
# :free (Qualitaet variiert, koennen jederzeit deaktiviert werden):
#   google/gemini-2.5-flash:free
#   meta-llama/llama-3.3-70b-instruct:free
#   mistralai/mistral-small-3.1-24b-instruct:free
# Kostenpflichtig (maximal stabil): anthropic/claude-sonnet-4, openai/gpt-4o
LLM_MODEL=openrouter/elephant-alpha

# HTTP-Timeout (ms) und Retry-Count fuer LLM-Calls. Schuetzt vor haengenden
# Free-Tier-Providern. Default: 60s, 2 Retries.
# LLM_HTTP_TIMEOUT_MS=60000
# LLM_MAX_RETRIES=2

# Max Tool-Rounds pro Nachricht (default 80) — das ist die HARTE Obergrenze.
# Bei langen Multi-Step-Ketten (viele Notizen lesen + zusammenfassen, mehrere
# Dateien bearbeiten) rechnen wir mit 20-40 Runden. 80 schuetzt nur vor
# Runaway-Loops (die werden zusaetzlich per 3x-identischer-Call erkannt).
# MAX_TOOL_ROUNDS=80

# Soft-Cap: ab dieser Runde wird einmalig ein "bitte fokussiert wrappen"-Hint
# eingeschoben. Agent darf weiter Tools callen. Default 25.
# SOFT_TOOL_ROUNDS=25

# --- Alternative: Ollama lokal (kein API-Key noetig) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# --- Alternative: OpenAI direkt ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# OpenRouter Dashboard-Label (optional)
# LLM_APP_NAME=Obsidian-OS

# ── Sicherheit ────────────────────────────────────────────────────────────────

# Nur diese Chat-ID darf den Bot nutzen.
# Leer lassen = jeder darf schreiben (nur fuer Erst-Setup!).
# Chat-ID rausfinden: Bot anschreiben, dann /status im Telegram.
ALLOWED_CHAT_ID=

# ── OneDrive (rclone im Container) ───────────────────────────────────────────

# Token von: rclone authorize "onedrive" (am lokalen PC ausfuehren)
RCLONE_TOKEN=

# Pfad zum Vault innerhalb von OneDrive (z.B. Obsidian/MeinVault)
ONEDRIVE_VAULT_PATH=

# Drive-Typ: personal / business / documentLibrary
ONEDRIVE_DRIVE_TYPE=

# Drive-ID (optional — wird automatisch erkannt)
ONEDRIVE_DRIVE_ID=

# ── System-Daten (Agent-State, Logs — getrennt vom User-Vault) ──────────────

# Pfad fuer Bot-Interna: SYSTEM.md, MEMORY.md, MEMORY_LOGS/
# Docker-Default (via docker-compose): /data  (separates Volume)
# SYSTEM_DATA_PATH=/data

# ── Optional ──────────────────────────────────────────────────────────────────

# VISION_MODEL=gpt-4o
# WHISPER_MODEL=large-v3
# WHISPER_LANG=de

# Max Bytes pro Telegram-Download (voice/photo/document). Schuetzt vor OOM.
# Default: 20 MB (Telegram Bot-API-Limit).
# MAX_FILE_BYTES=20971520

# Safety-Override: Bot startet auch wenn WORKSPACE_PATH keinen .obsidian/-
# Ordner enthaelt. Nur fuer Erst-Setup oder bewusstes Testen ohne Vault!
# Sonst wuerde bei fehlendem OneDrive-Mount der Bot still ins Container-FS
# schreiben und Notizen beim naechsten `docker compose down` verlieren.
# OBSIDIAN_UNSAFE=1
