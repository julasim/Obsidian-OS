# Obsidian-OS Konfiguration
# cp .env.example .env  →  Werte ausfuellen  →  docker compose up -d

# ── Pflicht ───────────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather)
BOT_TOKEN=

# Vault-Pfad (im Container immer /vault — nicht aendern)
WORKSPACE_PATH=/vault

# LLM API (OpenAI-kompatibel: Ollama Cloud, OpenAI, OpenRouter, lokales Ollama)
# Cloud:  https://api.ollama.com/v1
# OpenAI: https://api.openai.com/v1
# Lokal:  http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=https://api.ollama.com/v1

# API Key (Ollama Cloud, OpenAI, OpenRouter — bei lokalem Ollama leer lassen)
OLLAMA_API_KEY=

# LLM-Modell
OLLAMA_MODEL=kimi-k2.5:cloud

# ── Sicherheit ────────────────────────────────────────────────────────────────

# Nur diese Chat-ID darf den Bot nutzen (Bot starten → /whoami)
ALLOWED_CHAT_ID=

# ── Optional ──────────────────────────────────────────────────────────────────

# OLLAMA_FAST_MODEL=qwen2.5:7b
# OLLAMA_SUBAGENT_MODEL=qwen2.5:7b
# VISION_MODEL=llava

# Whisper (Sprachnachrichten)
WHISPER_MODEL=large-v3
WHISPER_LANG=de

# Obsidian-Ordner
# DAILY_NOTES_DIR=Daily
# TEMPLATES_DIR=Templates
# ATTACHMENTS_DIR=Attachments
