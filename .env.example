# Obsidian-OS Konfiguration

# ── Pflicht ───────────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather)
BOT_TOKEN=

# Vault-Pfad (im Container immer /vault)
WORKSPACE_PATH=/vault

# ── LLM-Provider ─────────────────────────────────────────────────────────────
# OpenRouter = Default (ein Key, viele Modelle: Claude, GPT-4o, Gemini, Llama...)
# Key holen: https://openrouter.ai → Dashboard → API Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-...

# Modell (OpenRouter-Format: provider/model)
# Empfohlen: anthropic/claude-sonnet-4, openai/gpt-4o, google/gemini-2.5-pro
LLM_MODEL=anthropic/claude-sonnet-4

# --- Alternative: Ollama lokal (kein API-Key noetig) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# --- Alternative: OpenAI direkt ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# OpenRouter Dashboard-Label (optional)
# LLM_APP_NAME=Obsidian-OS

# ── Sicherheit ────────────────────────────────────────────────────────────────

# Nur diese Chat-ID darf den Bot nutzen.
# Leer lassen = jeder darf schreiben (nur fuer Erst-Setup!).
# Chat-ID rausfinden: Bot anschreiben, dann /status im Telegram.
ALLOWED_CHAT_ID=

# ── OneDrive (rclone im Container) ───────────────────────────────────────────

# Token von: rclone authorize "onedrive" (am lokalen PC ausfuehren)
RCLONE_TOKEN=

# Pfad zum Vault innerhalb von OneDrive (z.B. Obsidian/MeinVault)
ONEDRIVE_VAULT_PATH=

# Drive-Typ: personal / business / documentLibrary
ONEDRIVE_DRIVE_TYPE=

# Drive-ID (optional — wird automatisch erkannt)
ONEDRIVE_DRIVE_ID=

# ── System-Daten (Agent-State, Logs — getrennt vom User-Vault) ──────────────

# Pfad fuer Bot-Interna: SYSTEM.md, MEMORY.md, MEMORY_LOGS/
# Docker-Default (via docker-compose): /data  (separates Volume)
# SYSTEM_DATA_PATH=/data

# ── Optional ──────────────────────────────────────────────────────────────────

# VISION_MODEL=gpt-4o
# WHISPER_MODEL=large-v3
# WHISPER_LANG=de
